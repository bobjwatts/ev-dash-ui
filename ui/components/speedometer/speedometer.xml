<component>
	<previews>
		<preview width="439" height="439" style_bg_color="#COLOR_BG" />
	</previews>

	<api>
		<prop name="speed" type="subject" default="speed_kmh" />
		<prop name="needle_angle" type="subject" default="speed_needle_angle" />
	</api>

	<view width="439" height="439" style_bg_opa="0" style_border_width="0" scrollable="false">
		<!-- dial_speed_dial: face+border baked from sc_* PNGs at native size (439x439) -->
		<lv_image src="dial_speed_dial" align="center" />
		<speed_scale_ring value="$speed" align="center" />
		<speed_scale_ring_fine value="$speed" align="center" />
		<lv_image
			src="dial_speed_needle"
			align="top_mid"
			y="35"
			style_transform_pivot_x="11"
			style_transform_pivot_y="153"
			style_bg_opa="0"
		>
			<!-- pivot/y: set for your resized needle PNG (rotation centre at dial hub) -->
			<bind_style_prop prop="transform_rotation" subject="$needle_angle" />
		</lv_image>

		<gauge_center_readout value="$speed" unit="km/h" value_y="-11" unit_y="30" align="center" />
	</view>
</component>
