<component>
	<previews>
		<preview width="380" height="380" style_bg_color="#COLOR_BG" />
	</previews>

	<api>
		<prop name="value" type="subject" default="speed_kmh" />
	</api>

	<styles>
		<style name="scale_ticks" line_color="#COLOR_WHITE" line_width="2" length="11" />
		<style name="scale_ticks_dark" line_color="#COLOR_GREEN" line_width="2" length="11" />
		<style name="scale_section_ticks" line_color="#COLOR_GAUGE_ACTIVE" line_width="2" length="7" />

		<style
			name="scale_main"
			width="141"
			height="141"
			arc_width="0"
			text_font="font_small"
			text_color="#COLOR_GREEN"
		/>
		<style name="scale_main_dark" text_color="#COLOR_GREEN_DARK" text_font="font_small" />
	</styles>

	<view
		extends="lv_scale"
		major_tick_every="0"
		mode="round_inner"
		angle_range="220"
		min_value="0"
		max_value="200"
		rotation="-200"
		width="380"
		height="380"
		style_arc_width="1"
		style_radius="42"
		style_align="center"
		style_radial_offset="32"
		style_text_color="#COLOR_GAUGE_ACTIVE"
		style_text_align="center"
		style_line_dash_width="200"
		draw_ticks_on_top="true"
		total_tick_count="120"
		scrollable="false"
	>
		<style name="scale_main" />
		<bind_style name="scale_main_dark" subject="dark_theme" ref_value="1" />
		<style name="scale_ticks" selector="items" />
		<style name="scale_ticks" selector="indicator" />

		<bind_style name="scale_ticks_dark" subject="dark_theme" ref_value="1" selector="items" />
		<bind_style name="scale_ticks_dark" subject="dark_theme" ref_value="1" selector="indicator" />

		<lv_scale-section
			min_value="0"
			bind_max_value="$value"
			style_items="scale_section_ticks"
			style_indicator="scale_section_ticks"
		/>
	</view>
</component>
