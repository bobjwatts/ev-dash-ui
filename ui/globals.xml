<globals>
	<api>
		<!-- Gear selector state -->
		<enumdef name="GearPosition">
			<enum name="GEAR_PARK" value="0" />
			<enum name="GEAR_REVERSE" value="1" />
			<enum name="GEAR_NEUTRAL" value="2" />
			<enum name="GEAR_DRIVE" value="3" />
			<enum name="GEAR_BRAKE" value="4" />
		</enumdef>

		<!-- Ready / fault state for status indicators -->
		<enumdef name="SysState">
			<enum name="SYS_FAULT" value="0" />
			<enum name="SYS_READY" value="1" />
			<enum name="SYS_ACTIVE" value="2" />
			<enum name="SYS_CHARGE" value="3" />
		</enumdef>
	</api>

	<consts>
		<!-- ── Brand palette ─────────────────────────────────── -->
		<color name="COLOR_YELLOW" value="0xFAD719" />
		<color name="COLOR_YELLOW_DARK" value="0xFF6F00" />
		<color name="COLOR_GREY_LIGHT" value="0xD9D9D9" />
		<color name="COLOR_GREY_DARK" value="0x474645" />
		<color name="COLOR_GREEN" value="0x0DFF00" />
		<color name="COLOR_GREEN_MID" value="0x235F3F" />
		<color name="COLOR_GREEN_DARK" value="0x042A16" />
		<color name="COLOR_BLUE" value="0x00B2FF" />
		<color name="COLOR_WHITE" value="0xFFFFFF" />

		<!-- ── Semantic roles (map to palette above) ─────────── -->
		<color name="COLOR_BG" value="0x1F1F24" />
		<color name="COLOR_SURFACE" value="0x235F3F" />
		<color name="COLOR_BORDER" value="0x474645" />

		<color name="COLOR_ACCENT" value="0x00B2FF" />
		<color name="COLOR_ACCENT_DIM" value="0x235F3F" />

		<color name="COLOR_OK" value="0x0DFF00" />
		<color name="COLOR_WARNING" value="0xFF6F00" />
		<color name="COLOR_DANGER" value="0xFF6F00" />

		<color name="COLOR_TEXT_HI" value="0xFFFFFF" />
		<color name="COLOR_TEXT_MID" value="0xD9D9D9" />
		<color name="COLOR_TEXT_LO" value="0x474645" />

		<!-- Gauge / dial -->
		<color name="COLOR_GAUGE_ACTIVE" value="0xFAD719" />
		<color name="COLOR_GAUGE_TRACK" value="0x235F3F" />

		<!-- Typography sizes (px) — scaled for 580 px dial on 1024×600 -->
		<int name="FONT_SIZE_DISPLAY" value="68" />
		<int name="FONT_SIZE_HEADING" value="28" />
		<int name="FONT_SIZE_BODY" value="16" />
		<int name="FONT_SIZE_SMALL" value="12" />

		<!-- SoC colour thresholds -->
		<int name="SOC_WARN_PCT" value="20" />
		<int name="SOC_CRIT_PCT" value="10" />

		<!-- Temp warning thresholds (°C) -->
		<int name="TEMP_WARN_C" value="70" />
		<int name="TEMP_CRIT_C" value="85" />
	</consts>

	<subjects>
		<!-- ── Drivetrain ─────────────────────────────────── -->
		<int name="speed_kmh" value="0" />
		<int name="gear" value="0" />
		<!-- maps to GearPosition enum -->
		<string name="gear_str" value="P" />
		<!-- firmware sets: P R N D B -->
		<int name="regen_level" value="0" />
		<!-- 0–3 paddle regen steps -->

		<!-- ── Power & energy ─────────────────────────────── -->
		<float name="power_kw" value="0.0" />
		<!-- + discharge / - regen -->
		<int name="energy_kwh_remaining" value="0" />

		<!-- ── Battery ────────────────────────────────────── -->
		<int name="state_of_charge_pct" value="100" />
		<float name="battery_voltage_v" value="0.0" />
		<float name="battery_current_a" value="0.0" />
		<int name="batt_temp_c" value="0" />

		<!-- ── Motor / inverter ───────────────────────────── -->
		<int name="motor_temp_c" value="0" />
		<int name="inverter_temp_c" value="0" />
		<int name="motor_rpm" value="0" />

		<!-- ── Trip / odometer ───────────────────────────── -->
		<int name="odometer_km" value="0" />
		<int name="trip_km" value="0" />
		<int name="range_est_km" value="0" />

		<!-- ── System status ─────────────────────────────── -->
		<int name="sys_state" value="1" />
		<!-- maps to SysState -->
		<int name="fault_code" value="0" />

		<int name="dark_theme" value="0" help="0:light 1:dark" />

		<int name="speed_needle_angle" value="-1090" />
	</subjects>

	<images>
		<!-- Firmware uses dial_speed_dial composite (tools/gen_image_data.ps1), not these entries directly -->
		<data name="dial_speed_needle" color_format="argb8888" src_path="images/sc_dial_speed_needle.png" />
		<data
			name="sc_dial_speed_face_border"
			color_format="argb8888"
			src_path="images/sc_dial_speed_face_border.png"
		/>
	</images>

	<fonts>
		<bin name="font_display" as_file="false" src_path="fonts/JetBrainsMono-Medium.ttf" size="68" bpp="4" />
		<bin name="font_heading" as_file="false" src_path="fonts/JetBrainsMono-Medium.ttf" size="28" bpp="4" />
		<bin name="font_body" as_file="false" src_path="fonts/JetBrainsMono-Regular.ttf" size="16" bpp="4" />
		<bin name="font_small" as_file="false" src_path="fonts/JetBrainsMono-Regular.ttf" size="12" bpp="4" />
	</fonts>
</globals>
